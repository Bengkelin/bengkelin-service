# Application Configuration
APP_NAME="Bengkelin API"
APP_VERSION="1.0.0"
APP_ENVIRONMENT="development"

# Server Configuration
SERVER_PORT="3000"
SERVER_SECRET=""
SERVER_SECRET2=""
# Refresh token secrets (should be different from access token secrets)
SERVER_REFRESH_SECRET=""
SERVER_REFRESH_SECRET2=""
# release | debug
SERVER_MODE="debug"
SERVER_NAME="bengkelin-api"
# Access token expires after (in hours)
SERVER_EXPIRES_HOUR=1
# Refresh token expires after (in hours) - typically much longer
SERVER_REFRESH_EXPIRES_HOUR=168  # 7 days
SERVER_HOST="localhost"
SERVER_DEV_MODE="false"

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
# General rate limiting (requests per second)
RATE_LIMIT_GENERAL_RPS=1.67  # 100 requests per minute (100/60)
RATE_LIMIT_GENERAL_BURST=10
# Auth endpoints rate limiting (more restrictive)
RATE_LIMIT_AUTH_RPS=0.17     # 10 requests per minute (10/60)
RATE_LIMIT_AUTH_BURST=5
# Strict rate limiting for login/register (most restrictive)
RATE_LIMIT_STRICT_RPS=0.083  # 5 requests per minute (5/60)
RATE_LIMIT_STRICT_BURST=2

# RabbitMQ Configuration
RABBITMQ_ENABLED=true

# Option 1: Use RabbitMQ URL (recommended for cloud/managed RabbitMQ)
# RABBITMQ_URL="amqp://user:password@host:port/vhost"

# Option 2: Use individual parameters (for local RabbitMQ)
RABBITMQ_HOST="localhost"
RABBITMQ_PORT="5672"
RABBITMQ_USERNAME="guest"
RABBITMQ_PASSWORD="guest"
RABBITMQ_VHOST="/"

# Redis Configuration
REDIS_ENABLED=true

# Option 1: Use Redis URL (recommended for cloud/managed Redis)
# REDIS_URL="redis://default:password@ipaddress:7001/0"

# Option 2: Use individual parameters (for local Redis)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB=0

# Database Configuration
# Supported drivers: mysql | postgres
DATABASE_DRIVER="mysql"
DATABASE_NAME="bengkelin_db"
DATABASE_USERNAME="root"
DATABASE_PASSWORD=
# DATABASE_HOST="db" # If you are using Docker, uncomment this and comment the other variable
DATABASE_HOST="localhost"
# Default ports: MySQL=3306, PostgreSQL=5432
DATABASE_PORT="3306"
DATABASE_MAX_LIFETIME=7200  # 2 hours
DATABASE_MAX_OPEN_CONNS=150 # 150 connections
DATABASE_MAX_IDLE_CONNS=50  # 50 connections

# PostgreSQL specific settings (only used when DATABASE_DRIVER=postgres)
POSTGRES_SSLMODE="disable"  # disable | require | verify-ca | verify-full
POSTGRES_TIMEZONE="Asia/Jakarta"

# MySQL specific settings (only used when DATABASE_DRIVER=mysql)
MYSQL_CHARSET="utf8mb4"
MYSQL_COLLATION="utf8mb4_unicode_ci"

BCRYPT_COST=12

# Storage Provider Configuration
# Options: local | cloudinary
STORAGE_PROVIDER="cloudinary"

# Cloudinary Configuration (only needed when STORAGE_PROVIDER=cloudinary)

# Option 1: Use Cloudinary URL (recommended)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# Option 2: Use individual parameters
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="bengkelin"