# Test Environment Configuration

# Database Configuration
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=bengkelin_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=password

# Redis Configuration
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379
TEST_REDIS_DB=1
TEST_REDIS_PASSWORD=

# RabbitMQ Configuration
TEST_RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# JWT Configuration
TEST_JWT_SECRET=test_jwt_secret_key_for_testing_only
TEST_JWT_REFRESH_SECRET=test_jwt_refresh_secret_key_for_testing_only

# Application Configuration
TEST_APP_PORT=3001
TEST_APP_ENV=test
TEST_APP_DEBUG=true

# Rate Limiting (disabled for tests)
TEST_RATE_LIMIT_ENABLED=false

# File Upload Configuration
TEST_UPLOAD_PATH=./tests/fixtures/uploads
TEST_MAX_FILE_SIZE=10485760

# External Services (mocked in tests)
TEST_AGORA_APP_ID=test_agora_app_id
TEST_AGORA_APP_CERTIFICATE=test_agora_certificate

# Logging Configuration
TEST_LOG_LEVEL=error
TEST_LOG_FORMAT=json